generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario Int        @id @default(autoincrement())
  nombre     String
  email      String     @unique
  password   String
  rol        RolUsuario
  ventas     Venta[]
}

model Cliente {
  id_cliente       Int        @id @default(autoincrement())
  nombre_completo  String
  dni              String?    @unique
  telefono         String?
  email            String?
  domicilio        String?
  ventas           Venta[]
  prestamos        Prestamo[]
  senias           Senia[]
  vehiculos   Vehiculo[]
}

model Vehiculo {
  id_vehiculo       Int            @id @default(autoincrement())
  marca             String?
  modelo            String?
  anio              Int?
  transmision       String?
  traccion          String?
  puertas           Int?
  motor             String?
  color             String?
  km                Int?
  patente           String?        @unique
  vin               String?
  precio_compra_usd Decimal?       @db.Decimal(10, 2)
  precio_compra_ars Decimal?       @db.Decimal(12, 2)
  precio_venta_usd  Decimal?       @db.Decimal(10, 2)
  precio_venta_ars  Decimal?       @db.Decimal(12, 2)
  estado            EstadoVehiculo @default(EN_PREPARACION)
  fecha_ingreso     DateTime       @default(now())
  tipo_ingreso      String?        @default("Propio") 
  comision_consignacion_pct Decimal? @db.Decimal(5, 2)
  
  ventas            Venta[]
  tareas            Tarea[]
  senias            Senia[]
  fotos             VehiculoFoto[] // Faltaba esta línea
  anotaciones       Anotacion[]    // Y faltaba esta línea
  notas_internas  String?  @db.Text
  id_cliente  Int?
  cliente     Cliente?  @relation(fields: [id_cliente], references: [id_cliente])
  
}

model VehiculoFoto {
  id_foto     Int      @id @default(autoincrement())
  id_vehiculo Int
  url_foto    String   // Ruta de la imagen guardada
  vehiculo    Vehiculo @relation(fields: [id_vehiculo], references: [id_vehiculo], onDelete: Cascade)
}

model Anotacion {
  id_anotacion Int      @id @default(autoincrement())
  id_vehiculo  Int
  texto        String   @db.Text
  fecha        DateTime @default(now())
  vehiculo     Vehiculo @relation(fields: [id_vehiculo], references: [id_vehiculo], onDelete: Cascade)
}

model Configuracion {
  clave String @id
  valor String @db.LongText
}

model Venta {
  id_venta               Int          @id @default(autoincrement())
  id_vehiculo            Int
  id_cliente             Int
  id_vendedor_interno    Int?
  precio_final_usd       Decimal      @db.Decimal(10, 2)
  forma_pago             FormaPago
  cotizacion_dolar_venta Decimal?     @db.Decimal(10, 2)
  fecha_venta            DateTime     @default(now())
  vehiculo               Vehiculo     @relation(fields: [id_vehiculo], references: [id_vehiculo])
  cliente                Cliente      @relation(fields: [id_cliente], references: [id_cliente])
  vendedor               Usuario?     @relation(fields: [id_vendedor_interno], references: [id_usuario])
  cuotas                 VentaCuota[]
}

model VentaCuota {
  id_cuota          Int      @id @default(autoincrement())
  id_venta          Int
  numero_cuota      Int
  monto_usd         Decimal
  fecha_vencimiento DateTime
  estado            String   @default("PENDIENTE")

  // IMPORTANTE: Los 3 campos nuevos para la cobranza inteligente
  monto_pagado_ars  Decimal?
  cotizacion_pago   Decimal?
  fecha_pago        DateTime?

  venta             Venta    @relation(fields: [id_venta], references: [id_venta])
}

model Prestamo {
  id_prestamo               Int             @id @default(autoincrement())
  id_cliente                Int
  
  // Nuevos campos financieros avanzados
  capital_entregado_usd     Decimal
  total_devolver_usd        Decimal
  cotizacion_dolar_prestamo Decimal
  fecha_prestamo            DateTime        @default(now())
  estado                    String          @default("ACTIVO")

  // Relaciones
  cliente                   Cliente         @relation(fields: [id_cliente], references: [id_cliente])
  cuotas                    PrestamoCuota[]
}

model PrestamoCuota {
  id_cuota          Int       @id @default(autoincrement())
  id_prestamo       Int
  numero_cuota      Int
  monto_usd         Decimal
  fecha_vencimiento DateTime
  estado            String    @default("PENDIENTE")
  
  // Historial de pagos inteligente
  monto_pagado_ars  Decimal?
  cotizacion_pago   Decimal?
  fecha_pago        DateTime?

  prestamo          Prestamo  @relation(fields: [id_prestamo], references: [id_prestamo])
}

model Tarea {
  id_tarea     Int         @id @default(autoincrement())
  id_vehiculo  Int
  descripcion  String
  estado_tarea EstadoTarea @default(PENDIENTE)
  vehiculo     Vehiculo    @relation(fields: [id_vehiculo], references: [id_vehiculo])
  gastos       Gasto[]
}

model Gasto {
  id_gasto        Int      @id @default(autoincrement())
  descripcion     String
  monto_usd       Decimal
  monto_ars       Decimal
  fecha           DateTime @default(now())
  
  // Campos para la caja
  categoria       String?
  tipo_movimiento String?  @default("EGRESO")

  // IMPORTANTE: El signo de interrogación (?) hace que la tarea NO sea obligatoria
  id_tarea        Int?
  tarea           Tarea?   @relation(fields: [id_tarea], references: [id_tarea])
}

model Senia {
  id_senia     Int         @id @default(autoincrement())
  id_vehiculo  Int
  id_cliente   Int
  fecha_senia  DateTime    @default(now())
  monto_usd    Decimal     @db.Decimal(10, 2)
  monto_ars    Decimal     @db.Decimal(12, 2)
  cotizacion   Decimal     @db.Decimal(10, 2)
  estado       EstadoSenia @default(ACTIVA)
  
  vehiculo     Vehiculo    @relation(fields: [id_vehiculo], references: [id_vehiculo], onDelete: Cascade)
  cliente      Cliente     @relation(fields: [id_cliente], references: [id_cliente])
}

enum RolUsuario {
  Admin
  Vendedor
  RRHH
}

enum EstadoVehiculo {
  EN_PREPARACION
  LISTO_PARA_VENTA
  EN_CONSIGNACION
  SENADO
  VENDIDO
}

enum FormaPago {
  Contado
  Cuotas
}

enum EstadoCuota {
  PENDIENTE
  PAGADA
}

enum EstadoPrestamo {
  EN_CURSO
  FINALIZADO
}

enum EstadoTarea {
  PENDIENTE
  FINALIZADA
}

enum EstadoSenia {
  ACTIVA
  CANCELADA
}


